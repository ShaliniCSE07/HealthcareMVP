generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}


enum UserRole {
  PATIENT
  DOCTOR
  ADMIN
}

enum DoctorStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AppointmentStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  PENDING
  REJECTED
}

enum ConsultationType {
  VIDEO
  IN_PERSON
}

model HealthMetric {
  id          String @id @default(cuid())
  patient     User   @relation("UserHealthMetrics", fields: [patientId], references: [id])
  patientId   String
  metricsJson String

  createdAt DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  profilePicUrl String?

  // Optional doctor-specific metadata (used when role == DOCTOR)
  specialization     String?
  experienceYears    Int?
  qualification      String?
  registrationNumber String?
  medicalCouncil     String?
  verificationDocumentUrl  String?
  verificationDocumentName String?
  rating             Float?        @default(4.8)
  doctorStatus       DoctorStatus? @default(VERIFIED)

  patientAppointments Appointment[] @relation("PatientAppointments")
  doctorAppointments  Appointment[] @relation("DoctorAppointments")

  // Additional relations
  healthMetrics    HealthMetric[]   @relation("UserHealthMetrics")
  doctorSchedule   DoctorSchedule?  @relation("UserDoctorSchedule")
  timeSlots        TimeSlot[]       @relation("UserTimeSlots")
  sentMessages     ChatMessage[]    @relation("MessageSender")
  receivedMessages ChatMessage[]    @relation("MessageReceiver")
  patientConsultationSummaries ConsultationSummary[] @relation("PatientConsultationSummaries")
  doctorConsultationSummaries  ConsultationSummary[] @relation("DoctorConsultationSummaries")

  // Medication reminders
  medicationOrders           MedicationOrder[]          @relation("PatientMedicationOrders")
  prescribedMedicationOrders MedicationOrder[]          @relation("MedicationPrescriber")
  medicationAdherence        MedicationAdherence[]      @relation("PatientMedicationAdherence")
  medicationAlertsAsDoctor   MedicationMissedDoseAlert[] @relation("DoctorMedicationAlerts")
  medicationAlertsAsPatient  MedicationMissedDoseAlert[] @relation("PatientMedicationAlerts")
  riskAlerts                 RiskAlert[]                 @relation("UserAlerts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MedicationOrder {
  id                   String  @id @default(cuid())
  patient              User    @relation("PatientMedicationOrders", fields: [patientId], references: [id])
  patientId            String

  prescribedBy         User?   @relation("MedicationPrescriber", fields: [prescribedByDoctorId], references: [id])
  prescribedByDoctorId String?

  name         String
  dosage       String
  instructions String?

  frequency  String
  timesJson  String
  startDate  String
  endDate    String
  durationDays Int
  active     Boolean @default(true)

  adherence MedicationAdherence[]
  alerts    MedicationMissedDoseAlert[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, startDate, endDate])
}

model MedicationAdherence {
  id           String @id @default(cuid())
  doseId       String @unique

  patient   User @relation("PatientMedicationAdherence", fields: [patientId], references: [id])
  patientId String

  medicationOrder MedicationOrder @relation(fields: [medicationId], references: [id])
  medicationId    String

  scheduledAt DateTime
  status      String
  takenAt     DateTime?
  updatedAt   DateTime @default(now())
  updatedBy   String

  @@index([patientId, scheduledAt])
  @@index([medicationId, scheduledAt])
}

model MedicationMissedDoseAlert {
  id       String @id @default(cuid())
  doseId   String

  doctor   User @relation("DoctorMedicationAlerts", fields: [doctorId], references: [id])
  doctorId String

  patient   User @relation("PatientMedicationAlerts", fields: [patientId], references: [id])
  patientId String

  medicationOrder MedicationOrder @relation(fields: [medicationId], references: [id])
  medicationId    String

  scheduledAt   DateTime
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  acknowledgedAt DateTime?

  @@index([doctorId, status, createdAt])
  @@index([patientId, createdAt])
  @@index([medicationId, createdAt])
}

model Appointment {
  id              String            @id @default(cuid())
  patient         User              @relation("PatientAppointments", fields: [patientId], references: [id])
  patientId       String
  doctor          User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  doctorId        String
  date            String
  time            String
  status          AppointmentStatus @default(SCHEDULED)
  type            String
  consultationType ConsultationType

  // Optional linkage to a generated slot and OPD-style token
  slotId     String?
  tokenNumber Int?
  symptoms    String?
  notes       String?

  chatMessages ChatMessage[] @relation("AppointmentMessages")
  consultationSummaries ConsultationSummary[] @relation("AppointmentConsultationSummaries")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorSchedule {
  id                String   @id @default(cuid())
  doctor            User     @relation("UserDoctorSchedule", fields: [doctorId], references: [id])
  doctorId          String   @unique
  scheduleJson      String   // JSON-encoded DaySchedule[] from frontend
  slotDuration      Int      // minutes
  defaultMaxPatients Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TimeSlot {
  id         String @id
  doctor     User   @relation("UserTimeSlots", fields: [doctorId], references: [id])
  doctorId   String
  date       String
  startTime  String
  endTime    String
  maxPatients Int
  bookedCount Int   @default(0)
  isBlocked   Boolean @default(false)
  isEmergency Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id               String      @id @default(cuid()) @map("message_id")
  appointment      Appointment @relation("AppointmentMessages", fields: [appointmentId], references: [id])
  appointmentId    String      @map("appointment_id")
  sender           User        @relation("MessageSender", fields: [senderId], references: [id])
  senderId         String      @map("sender_id")
  receiver         User        @relation("MessageReceiver", fields: [receiverId], references: [id])
  receiverId       String      @map("receiver_id")
  senderRole       UserRole
  content          String      @map("message_text")
  attachmentUrl    String?     @map("attachment_url")
  attachmentType   String?
  encryptionKeyRef String?     @map("encryption_key_reference")
  isRead           Boolean     @default(false)

  createdAt DateTime @default(now()) @map("timestamp")

  @@index([appointmentId, createdAt])
  @@index([senderId, receiverId, createdAt])
  @@map("chat_messages")
}

model ConsultationSummary {
  id            String      @id @default(cuid())
  appointment   Appointment @relation("AppointmentConsultationSummaries", fields: [appointmentId], references: [id])
  appointmentId String
  patient       User        @relation("PatientConsultationSummaries", fields: [patientId], references: [id])
  patientId     String
  doctor        User        @relation("DoctorConsultationSummaries", fields: [doctorId], references: [id])
  doctorId      String

  transcript         String
  symptoms           String
  possibleCondition  String
  keyDiscussionPoints String
  recommendations    String
  followUpInstructions String
  rawJson            String
  disclaimer         String?

  createdAt DateTime @default(now())

  @@index([doctorId, patientId, createdAt])
  @@index([appointmentId, createdAt])
}

model RiskAlert {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserAlerts", fields: [userId], references: [id])
  message   String
  severity  String
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  @@index([userId, status, createdAt])
}
